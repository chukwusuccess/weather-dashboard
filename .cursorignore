# ============================================================================
# .cursorignore — blocks files from Cursor's INDEX and from AI ACCESS
# ----------------------------------------------------------------------------
# Portable template: drop into any repo. Syntax = .gitignore.
# Rule of thumb: if the AI should NEVER see it (secrets) or it can NEVER
# help (binaries, junk), it goes here. If it's just noisy-but-occasionally-
# useful (lockfiles), it goes in .cursorindexingignore instead.
#
# ⚠️ This is best-effort protection, not a security boundary. Real secrets
# should not live in the repo at all — use env vars / secret managers.
# ============================================================================

# --- Secrets & credentials (never expose to AI) -----------------------------
.env
.env.*
!.env.example
!.env.template
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.der
*.keystore
*.jks
id_rsa*
id_ed25519*
*.gpg
*.asc
credentials
credentials.*
secrets.*
*secret*
*credentials*.json
service-account*.json
.netrc
.npmrc
.pypirc
.aws/
.ssh/
*.tfstate
*.tfstate.*
*.tfvars

# --- Dependencies (huge, zero signal — read docs/types instead) -------------
node_modules/
vendor/
.venv/
venv/
env/
.bundle/
bower_components/
.pnpm-store/

# --- Build output & generated artifacts --------------------------------------
dist/
build/
out/
.next/
.nuxt/
.svelte-kit/
.output/
.vercel/
.netlify/
target/
bin/
obj/
__pycache__/
*.pyc
.gradle/
*.egg-info/
.eggs/
coverage/
.nyc_output/
htmlcov/
storybook-static/

# --- Caches & tool state ------------------------------------------------------
.cache/
.parcel-cache/
.turbo/
.eslintcache
.stylelintcache
.mypy_cache/
.pytest_cache/
.ruff_cache/
.tox/
.terraform/
.docusaurus/
tmp/
temp/

# --- Logs & runtime junk ------------------------------------------------------
*.log
logs/
npm-debug.log*
yarn-error.log*
pnpm-debug.log*
*.pid
*.seed

# --- Databases & data dumps (often contain real user data) -------------------
*.sqlite
*.sqlite3
*.db
*.dump
*.sql.gz
*.bak
*.backup

# --- Large binaries & media (AI can't read them; they bloat the index) -------
*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z
*.iso
*.dmg
*.exe
*.dll
*.so
*.dylib
*.o
*.a
*.wasm
*.mp4
*.mov
*.avi
*.mkv
*.mp3
*.wav
*.flac
*.psd
*.ai
*.sketch
*.fig
*.blend
*.pdf
*.ttf
*.otf
*.woff
*.woff2
*.eot

# --- OS & editor junk ---------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~
.idea/

# --- ML / large assets ---------------------------------------------------------
*.h5
*.ckpt
*.safetensors
*.onnx
*.pt
*.pth
*.parquet
*.feather

# ============================================================================
# Per-project additions go below this line (keep the template above generic)
# ============================================================================
